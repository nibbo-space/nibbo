# Database - Generate with: openssl rand -base64 32
DB_PASSWORD=your_secure_password_here

# Database URLs - Dev or production database connection
# Dev example: postgresql://homecrm:homecrm_local@127.0.0.1:5432/homecrm
DATABASE_URL=postgresql://user:password@host:5432/dbname
DIRECT_URL=postgresql://user:password@host:5432/dbname

# Authentication
AUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_256bit_secret_here

# Google OAuth Credentials (from Google Cloud Console)
# 1. Create OAuth 2.0 Client ID at console.cloud.google.com
# 2. Add Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here

# File Upload Configuration
UPLOAD_DIR=./uploads
PROJECT_ROOT=./

# Admin Configuration - Comma-separated email addresses
ADMIN_EMAILS=admin@example.com

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_REQUIRE_TLS=
SMTP_FROM=
FEEDBACK_TO=

NEXT_PUBLIC_APP_NAME=Nibbo

# Web Push (PWA). Optional — without keys, in-app bell still works; push UI stays hidden.
# Generate: node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log('NEXT_PUBLIC_VAPID_PUBLIC_KEY='+k.publicKey);console.log('VAPID_PRIVATE_KEY='+k.privateKey)"
# VAPID_SUBJECT=mailto:you@example.com

NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Optional GA4 measurement ID (G-XXXXXXXXXX). Scripts load only after cookie banner Accept.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

ASSISTANT_OLLAMA_BASE_URL=https://ollama.com
ASSISTANT_OLLAMA_MODEL=gpt-oss:20b-cloud

TMDB_API_KEY=

# Optional: `npm run db:seed` — випадкові [seed] родини та користувачі (логін лише Google; email для фікстур)
# SEED=42
# SEED_FAMILIES=8
# SEED_MEMBERS_PER_FAMILY=2
# SEED_RESET=1

#FIREBASE_PROJECT_ID =
#FIREBASE_CLIENT_EMAIL =
#FIREBASE_PRIVATE_KEY =
#MOBILE_JWT_SECRET =

#NIBBO_GEO_BLOCK_COUNTRIES=RU